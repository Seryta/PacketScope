    <string name="source_name_live_with_status">Live :%1$d  (%2$s)</string>

    <!-- Notification -->
    <string name="notif_channel_name">Live capture</string>
    <string name="notif_channel_desc">PCAPdroid UDP Exporter ingestion</string>
    <string name="notif_title">PacketScope live capture</string>
    <!-- 第 2 参数是已 format 的 plurals 字符串（caller 用 resources.getQuantityString
         拼 count_packets_received 后传进来），避免 plurals 拼 port 一个资源里 -->
    <string name="notif_text">Port :%1$d · %2$s</string>
    <string name="notif_action_stop" tools:ignore="DuplicateStrings">Stop listening</string>

    <!-- Filter parser errors (mapped from sealed FilterParseError in UI) -->
    <string name="filter_error_missing_right_paren">Missing closing parenthesis</string>
    <string name="filter_error_expected_right_paren">Expected \")\" but got \"%1$s\"</string>
    <string name="filter_error_unexpected_end_of_expr">Unexpected end of expression</string>
    <string name="filter_error_expected_digit">Expected a number, got \"%1$s\"</string>
    <string name="filter_error_port_out_of_range">Port must be 0..65535, got %1$d</string>
    <string name="filter_error_unknown_token">Unknown token: \"%1$s\"</string>
    <string name="filter_error_missing_arg">Missing argument after \"%1$s\"</string>
    <string name="filter_error_extra_token">Extra token: \"%1$s\"</string>

    <!-- Errors (user-facing PcapLoader / loader failures) -->
    <string name="error_open_stream_null">ContentResolver.openInputStream returned null</string>
    <string name="error_open_stream">Failed to open file: %1$s</string>
    <string name="error_parse">Parse failed: %1$s</string>
    <string name="error_unexpected">Unexpected error: %1$s</string>
    <string name="error_pcapng_unsupported">PacketScope does not support PCAPng yet. In PCAPdroid choose the PCAP export (not PCAPng), or convert with: tshark -F pcap -r in.pcapng -w out.pcap</string>
    <string name="error_file_too_large">File size %1$d MB exceeds the %2$d MB threshold. The current build loads the whole file into memory and would OOM on this device; lazy paging is on the v0.9 roadmap.</string>

    <!-- Plurals: 单复数 quantity strings。英文 quantity=one 覆盖 n==1，quantity=other
         覆盖其它（包括 0）。中文 values-zh 只放 quantity=other。 -->
    <plurals name="count_packets">
        <item quantity="one">%d packet</item>
        <item quantity="other">%d packets</item>
    </plurals>
    <plurals name="count_packets_received">
        <item quantity="one">%d packet received</item>
        <item quantity="other">%d packets received</item>
    </plurals>
    <plurals name="count_bytes">
        <item quantity="one">%d byte</item>
        <item quantity="other">%d bytes</item>
    </plurals>
    <plurals name="count_characters">
        <item quantity="one">%d character</item>
        <item quantity="other">%d characters</item>
    </plurals>
    <plurals name="count_sessions">
        <item quantity="one">%d session</item>
        <item quantity="other">%d sessions</item>
    </plurals>
    <plurals name="count_session_keys_loaded">
        <item quantity="one">%d session key loaded</item>
        <item quantity="other">%d session keys loaded</item>
    </plurals>
    <plurals name="count_segments">
        <item quantity="one">%d segment</item>
        <item quantity="other">%d segments</item>
    </plurals>
    <plurals name="count_matches">
        <item quantity="one">%d match</item>
        <item quantity="other">%d matches</item>
    </plurals>
</resources>
