    <string name="conv_stat_total_bytes">Total bytes</string>
    <string name="conv_stat_duration">Duration</string>
    <string name="conv_stat_a_to_b_packets">A → B packets</string>
    <string name="conv_stat_a_to_b_bytes">A → B bytes</string>
    <string name="conv_stat_b_to_a_packets">B → A packets</string>
    <string name="conv_stat_b_to_a_bytes">B → A bytes</string>
    <!-- No trailing whitespace: stripped by resource loader. Spacing handled in UI. -->
    <string name="conv_app_label">App:</string>

