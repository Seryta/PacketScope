    <string name="about_link_pcapdroid_desc">No-root packet capture for Android. PacketScope is designed to read the .pcap files PCAPdroid exports.</string>
    <string name="about_action_check_updates">Check for updates</string>
    <string name="about_action_feedback">Report an issue</string>
    <string name="about_version_label">Version %1$s (build %2$d)</string>
    <string name="error_no_browser">No browser available to open URL</string>

    <!-- 全屏搜索栏（SearchHeaderBar，Frame detail / Follow stream 共用） -->
    <string name="search_placeholder">Search…</string>
    <string name="search_action">Search</string>
    <string name="search_close">Close search</string>
    <string name="search_prev_match">Previous match</string>
    <string name="search_next_match">Next match</string>

    <!-- Follow stream -->
    <string name="follow_stream_empty">No payload in this TCP stream</string>
    <string name="follow_stream_title">TCP Stream</string>
