    <string name="filter_example_google_dns">Google DNS</string>
    <string name="filter_example_no_tcp">Exclude TCP</string>
    <string name="filter_example_tcpudp_no_dns">TCP/UDP but not DNS</string>
    <string name="filter_example_post_login">POST login requests</string>
    <string name="filter_example_chrome_dns">Chrome doing Google DNS</string>

    <!-- Frame detail -->
    <string name="frame_detail_title">Frame #%1$d</string>
    <!-- No leading whitespace: Android resource loading strips it.
         Call site adds two-space gap via plain concatenation / Spacer. -->
    <string name="frame_detail_truncation">⚠ truncated %1$d/%2$dB</string>
    <!-- "%d bytes" 部分走 plurals.count_bytes，layers 列表由 UI 拼接 -->
    <string name="frame_detail_layer_truncated">(truncated)</string>

    <!-- Conversations -->
    <string name="conv_detail_title">Conversation detail</string>
    <string name="conv_section_endpoints">Endpoints</string>
    <string name="conv_section_stats">Stats</string>
