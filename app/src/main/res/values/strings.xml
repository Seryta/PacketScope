    <string name="section_payload">Payload</string>
    <string name="section_hex_dump">Hex dump</string>
    <!-- PayloadHeader summary 里的 kind 标签 -->
    <string name="payload_kind_utf8">UTF-8</string>
    <string name="payload_kind_binary">binary</string>
    <!-- 顶栏一键展开 / 收缩按钮（contentDescription，TalkBack 念出来） -->
    <string name="action_expand_all">Expand all</string>
    <string name="action_collapse_all">Collapse all</string>
    <!-- ⤢ 字段全屏按钮（FieldRow / PayloadHeader） -->
    <string name="action_open_fullscreen">View fullscreen</string>
