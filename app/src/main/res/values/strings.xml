<?xml version="1.0" encoding="utf-8"?>
<!--
  Default locale resources (English). Android falls back to this file when
  the device locale doesn't match a more specific values-<lang>/ folder.
  See res/values-zh/strings.xml for Simplified Chinese.

  DuplicateStrings 容忍说明：本文件存在若干 key 共享同一词面值但语义/上下文
  不同（如 header_protocol vs filter_section_protocols、action_stop_listen vs
  notif_action_stop）。这是 i18n 灵活性保留——未来翻译时可能需要按上下文分化
  语调（按钮 vs 节标题 vs 通知 action label）。lint 的 DuplicateStrings 在这
  几条 key 上是误报，相应条目用 tools:ignore 显式表达意图。
  review v0.6-round4 F-007。

  Naming convention:
    app_*      product / branding strings
    action_*   button labels (verbs, short)
    nav_*      top-level navigation labels
    dialog_*   AlertDialog / Dialog titles + bodies
    status_*   status / progress lines, never user actions
    hint_*     non-blocking helper text
    error_*    user-facing failures
    header_*   table / column headers
    filter_*   filter expression UI (input + help dialog)
    notif_*    foreground service notification text
    conv_*     conversations list / detail
-->
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- app / branding -->
    <string name="app_name">PacketScope</string>
    <string name="app_subtitle">Android PCAP viewer</string>
    <string name="open_pcap_action">Open with PacketScope</string>

    <!-- generic actions -->
    <string name="action_back">Back</string>
    <string name="action_cancel">Cancel</string>
    <string name="action_close">Close</string>
    <string name="action_clear">Clear</string>
    <string name="action_clear_data">Clear data</string>
    <string name="action_copy">Copy</string>
    <string name="action_follow_stream">Follow stream</string>
    <string name="action_follow_tcp_stream">Follow TCP stream  →</string>

    <!-- OpenFileScreen -->
    <string name="action_open_pcap">Open PCAP file</string>
    <string name="action_listen_pcapdroid">Listen for PCAPdroid</string>
    <string name="action_load_keylog">Load SSLKEYLOGFILE…</string>
    <string name="status_parsing">Parsing…</string>
    <string name="hint_share_pcap">You can also share .pcap files from PCAPdroid or a file manager</string>

    <!-- Listen-port dialog -->
    <string name="dialog_listen_title">Listen for PCAPdroid UDP Exporter</string>
    <string name="dialog_listen_port_label">UDP port</string>
    <string name="dialog_listen_hint">In PCAPdroid choose UDP Exporter mode,\nCollector: 127.0.0.1   Port: %1$s</string>
    <string name="action_start_listen">Start listening</string>

    <!-- Frame list -->
    <string name="nav_conversations">Conversations</string>
    <string name="header_time">Time</string>
    <string name="header_protocol" tools:ignore="DuplicateStrings">Protocol</string>
    <string name="header_length">Length</string>
    <string name="header_info">Info</string>
    <string name="filter_placeholder">Filter: tcp / port 53 / host 1.1.1.1 / sni example</string>
    <string name="dialog_stop_listen_title">Stop listening?</string>
    <string name="dialog_stop_listen_text">Listening for live PCAPdroid data. Closing will stop receiving.</string>
    <string name="action_stop_listen" tools:ignore="DuplicateStrings">Stop listening</string>

    <!-- Filter help dialog -->
    <string name="filter_help_title">Filter syntax</string>
    <string name="filter_help_placeholder">Enter filter expression…</string>
    <string name="filter_section_protocols" tools:ignore="DuplicateStrings">Protocols</string>
    <string name="filter_section_addr_port">Address / Port</string>
    <string name="filter_section_l7">Application layer content</string>
    <string name="filter_section_combine">Combine</string>
    <string name="filter_section_examples">Examples</string>
