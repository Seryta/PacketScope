    <!-- protocol descriptions -->
    <string name="filter_proto_tcp">TCP</string>
    <string name="filter_proto_udp">UDP</string>
    <string name="filter_proto_dns">DNS (port 53 UDP/TCP)</string>
    <string name="filter_proto_http">Plain HTTP</string>
    <string name="filter_proto_tls">TLS / HTTPS handshake</string>
    <string name="filter_proto_quic">QUIC (UDP 443)</string>
    <string name="filter_proto_icmp">ICMP / ICMPv6</string>
    <string name="filter_proto_ip">IPv4 / IPv6</string>
    <string name="filter_proto_eth">Ethernet frame</string>
    <!-- field atom descriptions -->
    <string name="filter_field_host">Source or destination IP equals this address</string>
    <string name="filter_field_port">Source or destination port equals this number</string>
    <string name="filter_field_sni">Substring match against TLS / QUIC SNI</string>
    <string name="filter_field_url">Substring match against HTTP Host+path or SNI</string>
